{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "quality": "npm run check:tokens && npm run lint && npx tsc --noEmit && npx tsc --noEmit -p supabase/functions/tsconfig.json && npx vitest run && npm run build",
    "quality:quick": "npm run check:tokens && npm run lint && npx tsc --noEmit && npx tsc --noEmit -p supabase/functions/tsconfig.json && npx vitest run",
    "lint:supabase-functions": "eslint supabase/functions",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "supabase:deploy": "supabase functions deploy --project-ref qynjzojmuarpcznepatt --use-api --yes",
    "supabase:deploy:chat": "supabase functions deploy chat-assistant",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref qynjzojmuarpcznepatt",
    "supabase:link-with-password": "node scripts/supabase-link-with-password.cjs",
    "supabase:db-push": "supabase db push --yes",
    "supabase:db-push:interactive": "supabase db push",
    "check:tokens": "node scripts/check-token-regressions.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.54.0",
    "@types/dagre": "^0.7.54",
    "@types/react-router-dom": "^5.3.3",
    "@xyflow/react": "^12.10.2",
    "@zegocloud/zego-uikit-prebuilt": "^2.17.0",
    "dagre": "^0.8.5",
    "html2pdf.js": "^0.12.0",
    "lucide-react": "^0.344.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^23.0.0",
    "pg": "^8.20.0",
    "postcss": "^8.4.35",
    "supabase": "^2.84.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^1.0.0"
  }
}
